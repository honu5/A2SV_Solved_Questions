class Solution:
    def removeComments(self, source: list[str]) -> list[str]:
        currB = False
        curr_Line = []
        code = []
        for line in source:
            idx = 0
            if not currB:
                curr_Line = []
            while idx < len(line):
                if not currB and idx+1 < len(line) and line[idx:idx+2] == '/*':
                    currB = True
                    idx += 2
                elif currB and idx+1 < len(line) and line[idx:idx+2] == '*/':
                    currB = False
                    idx += 2
                elif not currB and idx+1 < len(line) and line[idx:idx+2] == '//':
                    break
                elif not currB:
                    curr_Line.append(line[idx])
                    idx += 1
                else:
                    idx += 1
            if not currB and curr_Line:
                code.append(''.join(curr_Line))
        return code
