class Solution:
    def subarraysDivByK(self, nums: List[int], k: int) -> int:
        cnt=Counter({0:1})
        prefix_sum=0
        rem=0
        ans=0
        for num in nums:
            prefix_sum=(prefix_sum+num)%k
            ans+=cnt[prefix_sum]
            cnt[prefix_sum]+=1
        return ans
