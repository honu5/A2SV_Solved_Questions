class Solution(object):
    def minStartValue(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        cum=0
        for i in range(len(nums)):
            cum+=nums[i]
            nums[i]=cum
        if min(nums)>=1:
            return 1
        else: return 1-(min(nums))
        
