class Solution(object):
    def judgeSquareSum(self, c):
        """
        :type c: int
        :rtype: bool
        """
        ans=[ i for i in range(int(c**0.5)+1) ]
        l=0
        r=len(ans)-1
        while l<=r:
            val=(ans[l]**2)+(ans[r]**2)
            if val==c:
                return True
            elif val<c:
                l+=1
            else:
                r-=1
        return False

        
