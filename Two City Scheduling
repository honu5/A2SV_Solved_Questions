class Solution:
    def twoCitySchedCost(self, costs: List[List[int]]) -> int:
       
        costs.sort(key=lambda x:x[0]-x[1])
        res=0
        l=0
        r=len(costs)-1
    
        while l<r:
            ab=costs[l][1]+costs[r][0]
            ba=costs[l][0]+costs[r][1]
            res+=min(ab,ba)
            l+=1
            r-=1
        return res
        
        
