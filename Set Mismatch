class Solution(object):
    def findErrorNums(self, nums):
        """
        :type nums: List[int]
        :rtype: List[int]
        """
        
        count=Counter(nums)
        most=count.most_common()
        a=most[0][0]

        for i in range(1,len(nums)+1):
            if i not in nums:
                b=i
        return [a,b]
