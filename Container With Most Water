class Solution(object):
    def maxArea(self, height):
        """
        :type height: List[int]
        :rtype: int
        """
        l,r=0,len(height)-1
        val=0
        while l<=r:
            curr=min(height[l],height[r])*(r-l)
            val=max(val,curr)
            if height[l]>=height[r]:
                r-=1
            else:l+=1
        return val


        
