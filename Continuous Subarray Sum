class Solution:
    def checkSubarraySum(self, nums: List[int], k: int) -> bool:
        hash_map={0:-1}
        prefix=0
        for i in range(len(nums)):
            prefix+=nums[i]
            rem=prefix%k
            if rem in hash_map:
                if i-hash_map[rem]>1:
                    return True
            else: hash_map[rem]=i
        return False
        
        
        
