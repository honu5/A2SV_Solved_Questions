class Solution(object):
    def rotate(self, matrix):
        """
        :type matrix: List[List[int]]
        :rtype: None Do not return anything, modify matrix in-place instead.
        """
        n=len(matrix[0])
        m=len(matrix)-1
        matrixx=[]
        for j in range(n):
            temp=[]
            for i in range(len(matrix)-1,-1,-1):
                temp.append(matrix[i][j])
                print(i,j,m-i,temp)
                
            matrixx.append(temp)
        for i in range(m+1):
            matrix[i]=matrixx[i]


        
