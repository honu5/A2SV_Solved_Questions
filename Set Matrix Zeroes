class Solution(object):
    def setZeroes(self, matrix):
        """
        :type matrix: List[List[int]]
        :rtype: None Do not return anything, modify matrix in-place instead.
        """
        n=len(matrix[0])
        pos=[]
        mat=[]
        for i in range(len(matrix)):
            
            for j in range(n):
                if matrix[i][j]==0:
                    mat.append(i)
                    pos.append(j)
        if mat:
            print(mat)
            for i in mat:
                matrix[i]=[0]*n
        for k in range(len(matrix)):
            for l in pos:
                matrix[k][l]=0


        
