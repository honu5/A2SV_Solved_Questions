class Solution(object):
    def transpose(self, matrix):
        """
        :type matrix: List[List[int]]
        :rtype: List[List[int]]
        """
        ans=[]
        for i in range(len(matrix[0])):
            anss=[]
            for j in matrix:
                anss.append(j[i])
            ans.append(anss)
        return ans
            
            
                
        
