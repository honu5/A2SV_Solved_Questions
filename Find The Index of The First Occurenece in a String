class Solution(object):
    def strStr(self, haystack, needle):
        """
        :type haystack: str
        :type needle: str
        :rtype: int
        """
        if haystack==needle:
            return 0
        n=len(needle)
        if not needle in haystack:
            return -1
        
        for i in range(len(haystack)-n+1):
            if haystack[i]==needle[0]:
                if haystack[i:i+n]==needle:
                    return i
        return -1
