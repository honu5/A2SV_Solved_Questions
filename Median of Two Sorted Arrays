class Solution(object):
    def findMedianSortedArrays(self, nums1, nums2):
        """
        :type nums1: List[int]
        :type nums2: List[int]
        :rtype: float
        """
        
        nums=nums1 + nums2
        n=len(nums)
        nums.sort()
        if len(nums)%2==1:
            return float(nums[len(nums)//2])

        else:
            
            return ((nums[n/2]+nums[(n/2)-1])/2.00)
        
