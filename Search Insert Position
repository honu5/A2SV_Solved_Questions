class Solution:
    def searchInsert(self, nums: List[int], target: int) -> int:
        l,r=0,len(nums)-1
        if nums[0]>target:
            return 0
        if nums[-1]<target:
            return len(nums)
        while l<=r:
            mid=(l+r)//2
            if nums[mid]==target:
                return mid
            elif nums[mid]>target:
                if nums[mid-1]<target:
                    return mid
                else: r=mid-1
            else:
                if nums[mid+1]>target:
                    return mid+1
                else: l=mid+1


        
