class Solution:
    def scoreOfParentheses(self, s: str) -> int:
        val = 0
        stack = []
        i = 0

        while i < len(s):
            if s[i] == "(":
                stack.append("(")
            else:
                stack.pop()
                if s[i-1] == "(":
                    val += pow(2, len(stack))
            i += 1

        return val
