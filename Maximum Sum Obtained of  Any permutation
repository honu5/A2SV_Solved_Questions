class Solution:
    def maxSumRangeQuery(self, nums: List[int], requests: List[List[int]]) -> int:
        n=len(nums)
        cnt=[0 for i in range(n+1)]
        for s, e in requests:
            cnt[s]+=1
            cnt[e+1]-=1
        for i in range(1,n+1):
            cnt[i]+=cnt[i-1]
        res=0
        for a,b in zip(sorted(cnt[:n]),sorted(nums)):
            res+=(a*b)
        return res%((10**9)+7)

