class Solution(object):
    def findMinArrowShots(self, points):
        """
        :type points: List[List[int]]
        :rtype: int
        """
        points.sort(key=lambda x:x[1])
        arr=1
        curr=points[0][1]
        
        for i in range(len(points)):
            
            if points[i][0]>curr:
                arr+=1
                curr=points[i][1]
            

       
        return arr
           
        
