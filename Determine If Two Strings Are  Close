class Solution(object):
    def closeStrings(self, word1, word2):
        """
        :type word1: str
        :type word2: str
        :rtype: bool
        """
        if len(word1)!=len(word2):
            return False
        count1=Counter(word1)
        count2=Counter(word2)
        for i in count1:
            if i not in count2:
                return False
        for i in count1:
            if count2[i] < 0:
                return False
        lst=list(count1.values())
        lst2=list(count2.values())
        for i in lst:
            if i not in lst2:
                return False
            lst2.remove(i)
        return not lst2
        
