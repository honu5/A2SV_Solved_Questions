class Solution(object):
    def nextGreaterElement(self, nums1, nums2):
        """
        :type nums1: List[int]
        :type nums2: List[int]
        :rtype: List[int]
        """

        arr=[]
        for i in nums1:
            j=nums2.index(i)
            slced=nums2[j:]

            if max(slced)<=i:
                arr.append(-1)
                               
            else:
                for k in slced:
                
                    if k>i:
                        arr.append(k)
                        break
        return arr
        
