class Solution(object):
    def longestSubarray(self, nums):
        start=0
        maxx=0
        s0=0
        for i in range(len(nums)):
            if nums[i]==0:
                s0+=1
            while s0>1:
                if nums[start]==0:
                    s0-=1
                start+=1
            maxx=max(maxx,i-start)
        return maxx
