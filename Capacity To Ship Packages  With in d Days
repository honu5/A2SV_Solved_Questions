class Solution:
    def shipWithinDays(self, w: List[int], days: int) -> int:
        l=max(w)
        r=sum(w)
        while l<=r:
            curr=0
            d=1
            mid=(l+r)//2
            for i in w:
                if curr+i>mid:
                    d+=1
                    curr=0
                curr+=i
            if d>days:
                l=mid+1
            else: r=mid-1
        print(mid,l)
        return l
                
        
